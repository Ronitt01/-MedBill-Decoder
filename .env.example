# Google Gemini API key — get a free key at https://aistudio.google.com/apikey
# Set this in Vercel: Project Settings -> Environment Variables -> GEMINI_API_KEY
# NEVER commit the real key. It is only ever read server-side in /api/analyze.js
GEMINI_API_KEY=your_gemini_api_key_here

# Optional: override the model (defaults to gemini-2.0-flash)
GEMINI_MODEL=gemini-2.0-flash
